{
  "name": "restaurant-react-structure-preserve",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/vite/bin/vite.js build",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "start": "node server.js",
    "serve": "node server.js",
    "dev:host": "node node_modules/vite/bin/vite.js --host 0.0.0.0",
    "clean": "node -e \"const fs=require('fs'); for (const d of ['dist','.vite']) fs.rmSync(d,{recursive:true,force:true});\"",
    "db:migrate": "node server/db/migrate.js",
    "railway:start": "npm run db:migrate && npm start"
  },
  "dependencies": {
    "pg": "^8.13.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.7.0",
    "vite": "6.4.3"
  }
}
